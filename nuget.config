<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github.com/orgs/pepperdash" value="https://nuget.pkg.github.com/pepperdash/index.json" />
  </packageSources>
  <!--
    PepperDash.ZoomRoom.Sdk is published to the PepperDash org GitHub Packages feed.
    Local: configure once with read:packages creds for the "github.com/orgs/pepperdash" source
           (most PepperDash dev setups already have this in the user-level NuGet.Config).
    CI: GITHUB_TOKEN is scoped to epi-zoom-room and cannot read packages owned by zoom-room-sdk-lib.
        Add a classic PAT (read:packages) as repo secret PACKAGES_PAT; the reusable build workflow
        prefers it over GITHUB_TOKEN when authenticating this feed.
  -->
</configuration>
