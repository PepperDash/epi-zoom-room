<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="PepperDash-Engineering" value="https://nuget.pkg.github.com/PepperDash-Engineering/index.json" />
  </packageSources>
  <!--
    Credentials for PepperDash-Engineering are NOT stored here.
    Local: configure once with dotnet nuget add source, username and PAT with read:packages scope.
    CI: inject via the build workflow using a secret with read:packages scope on PepperDash-Engineering.
        The default GITHUB_TOKEN is scoped to the PepperDash org and cannot read cross-org packages.
  -->
</configuration>
